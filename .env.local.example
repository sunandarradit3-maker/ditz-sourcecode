# Rename this file to `.env.local` and fill in your Supabase project details.
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# If you need server-side admin privileges (not used directly in this example), set the service role key here.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key